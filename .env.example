# AION Repair OS V7.0 - Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit real secret values.

# AI provider selection
# Use "openrouter" or "deepseek" if you want to pin the provider.
AI_PROVIDER=openrouter

# OpenRouter configuration
# Get your token at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=http://localhost:3001
OPENROUTER_APP_NAME=AION Repair OS

# DeepSeek configuration
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# Runtime server
PORT=3001
HOST=127.0.0.1

# ADB bridge target
# Use this when the ADB server runs elsewhere, for example on a local companion bridge.
ADB_HOST=127.0.0.1
ADB_PORT=5037

# Logging
# LOG_LEVEL: debug, info, warn, error (default: info)
LOG_LEVEL=info
# LOG_FORMAT: text or json (default: text, use json for production/structured logging)
LOG_FORMAT=text

# Security
# Set ADMIN_TOKEN to protect sensitive endpoints (POST /api/ai/key, etc.)
ADMIN_TOKEN=
# Restrict CORS to your domain (leave empty for permissive mode)
CORS_ORIGIN=
# Rate limiting (per IP, per window)
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=30

# AI Executor (autonomous mode - opt-in)
# Set to true to enable the autonomous executor endpoints
EXECUTOR_ENABLED=false

# Hostinger deployment metadata
# Store these in a secret manager or deployment vault, not in a committed file.
HOSTINGER_API_TOKEN=
HAPI_API_TOKEN=
HOSTINGER_VM_ID=
HOSTINGER_SSH_HOST=
HOSTINGER_SSH_USER=
HOSTINGER_SSH_PORT=22
